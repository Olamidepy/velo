# ─────────────────────────────────────────────────────────────────────────────
# Velo API — environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and adjust for your target network.

PORT=3000

# --- Network ---
# Set to PUBLIC for Stellar Mainnet, TESTNET for Soroban testnet.
STELLAR_NETWORK=TESTNET
# Soroban RPC endpoint — change to https://soroban.stellar.org for mainnet.
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# --- x402 Merchant ---
# Stellar address that receives x402 payment for API calls.
# Testnet: any test address.   Mainnet: the address that collects USDC fees.
MERCHANT_ADDRESS=G...YOUR_MERCHANT_ADDRESS

# --- Escrow Contract ---
# The deployed escrow contract ID (C...).
# Testnet default is in @velo/shared; override here for mainnet after deployment.
ESCROW_CONTRACT_ID=CAEYSVTKTCZYTSMPD7CU3NOFYOO4S5V6LJLGRNV7LKTNZ65N66PCHLMC

# --- Custodial Signer (TESTNET ONLY) ---
# Secret key used to sign escrow transactions on behalf of the buyer.
# ⚠️  This MUST be empty/unset on mainnet.  On PUBLIC network the API refuses
#    to use a custodial key and only supports the non-custodial flow
#    (POST /cash/request/prepare → client signs → POST /cash/request/submit).
BUYER_SECRET_KEY=S...YOUR_TESTNET_SECRET_KEY

# --- Frontend ---
FRONTEND_BASE_URL=http://localhost:5181

# --- Admin ---
# Generate one with: openssl rand -hex 32
ADMIN_API_KEY=

# --- Refund Alerts ---
# Webhook URL for refund alerts (Slack or Discord). Leave empty to disable.
REFUND_WEBHOOK_URL=
