# --- Stellar / Soroban (source leg) ---
STELLAR_NETWORK=TESTNET
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# The deployed atomic-swap contract whose release() events we watch.
RELAYER_SOROBAN_CONTRACT_ID=SET_ME_AFTER_FIRST_DEPLOY
# Ledger to start scanning from. Leave empty to start from the latest ledger.
RELAYER_START_LEDGER=
# Poll interval in milliseconds.
RELAYER_POLL_INTERVAL_MS=5000

# --- EVM (counterpart leg) ---
# JSON-RPC endpoint for the EVM testnet (e.g. Sepolia).
EVM_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Private key of the relayer's EVM account (pays gas to submit withdraw()).
EVM_PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY
# Deployed HTLC.sol address on the EVM testnet.
EVM_HTLC_ADDRESS=0xYOUR_HTLC_CONTRACT_ADDRESS
