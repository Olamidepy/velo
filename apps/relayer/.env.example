# ─────────────────────────────────────────────────────────────────────────────
# Velo Cross-Chain Relayer — environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and adjust for your target network.

# --- Stellar / Soroban (source leg) ---
# Set to PUBLIC for Stellar Mainnet.
STELLAR_NETWORK=TESTNET
# Soroban RPC — change to https://soroban.stellar.org for mainnet.
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# The deployed atomic-swap contract whose release() events we watch.
# Set after mainnet deployment.
RELAYER_SOROBAN_CONTRACT_ID=SET_ME_AFTER_FIRST_DEPLOY
# Ledger to start scanning from. Leave empty to start from the latest ledger.
RELAYER_START_LEDGER=
# Poll interval in milliseconds (mainnet: 2000-5000 recommended).
RELAYER_POLL_INTERVAL_MS=5000

# --- EVM (counterpart leg) ---
# JSON-RPC endpoint for the EVM network (e.g. Ethereum mainnet).
EVM_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Private key of the relayer's EVM account (pays gas to submit withdraw()).
# ⚠️  Use a dedicated account with minimal ETH for gas only — never a
#    key that holds significant value.
EVM_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
# Deployed HTLC.sol address on the EVM network.
EVM_HTLC_ADDRESS=0xYOUR_HTLC_CONTRACT_ADDRESS
